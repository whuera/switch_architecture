    <!-- MODULOS -->
    <section id="modulos-section" class="section hidden">
        <div class="section-inner">
            <div class="section-header">
                <h2 class="section-title">Core <span class="gradient-text">Modules</span></h2>
                <p class="section-desc">Modulos principales del sistema BASE24-eps.</p>
            </div>
            <div class="modules-diagram-wrap">
                <img src="/images/core-modules-diagram.png" alt="Diagrama de Modulos Core" class="modules-diagram">
