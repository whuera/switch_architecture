                <div class="card-body">
                    <span class="card-tag">Modulos Core</span>
                    <h3>AUTH, MDS, Journal &amp; More</h3>
                    <p>Explora los modulos principales del sistema. Haz clic para ver el diagrama completo.</p>
                </div>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">&#129689;</div>
                    <h3>UI Components</h3>
                    <p>Interfaz de usuario moderna y reactiva para operaciones bancarias</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128268;</div>
                    <h3>API Integration</h3>
                    <p>Conectores para sistemas externos, cores bancarios y redes</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128218;</div>
                    <h3>Documentation</h3>
                    <p>Documentacion tecnica completa y actualizada del sistema</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128274;</div>
                    <h3>Security</h3>
                    <p>Criptografia EMV y validacion en cada capa del procesamiento</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SIMULADORES -->
    <section id="simuladores-section" class="section hidden">
