<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Switch Architecture</title>
    <link rel="stylesheet" href="/css/index.css">
    <script src="/js/d3.min.js"></script>
    <script src="/js/topojson-client.min.js"></script>
</head>
<body>

<!-- Grid overlay -->
<div class="bg-grid"></div>

<!-- Three.js canvas: orbs + connections -->
<canvas id="bg-canvas"></canvas>


<!-- ===== NAVBAR ===== -->
<header class="navbar">
    <div class="navbar-inner">
        <div class="navbar-brand">
            <div class="brand-icon">
                <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
                    <path d="M15 2L28 9.5V20.5L15 28L2 20.5V9.5L15 2Z" stroke="#0ea5e9" stroke-width="1.5" fill="rgba(14,165,233,0.08)"/>
                    <path d="M15 8L22 12V20L15 24L8 20V12L15 8Z" fill="rgba(14,165,233,0.35)"/>
                    <circle cx="15" cy="15" r="3" fill="#0ea5e9"/>
                    <circle cx="15" cy="15" r="1.2" fill="#fff"/>
                </svg>
            </div>
            <div class="brand-text">
                <span class="brand-title">B24-eps &amp; UPF</span>
                <span class="brand-sub">Consulting for Fintech</span>
            </div>
        </div>

        <nav class="navbar-nav">
            <a href="#" class="nav-link active" data-section="inicio">Inicio</a>
            <a href="#" class="nav-link" data-section="servicios">Servicios</a>
            <a href="#" class="nav-link" data-section="plataforma">Plataforma ACI</a>
            <a href="https://deepwiki.com/whuera/switch_architecture" class="nav-link" target="_blank" rel="noopener noreferrer">Wiki ↗</a>
            <a href="#" class="nav-link" data-section="simuladores">Simuladores</a>
        </nav>

        <div class="navbar-actions">
            <a href="https://github.com/whuera" target="_blank" rel="noopener noreferrer" class="nav-icon-btn" title="GitHub">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                </svg>
            </a>
            <button class="ai-btn" id="consultame-btn">
                <span class="ai-dot"></span>
                IA Asistente
            </button>
        </div>
    </div>
</header>

<!-- ===== MAIN CONTENT ===== -->
<main class="main">

    <!-- INICIO -->
    <section id="inicio-section" class="section active">
        <div class="section-inner">
            <div class="hero">
                <div class="hero-content">
                    <div class="hero-badge">
                        <span class="badge-dot"></span>
                        Consultora Especializada · ACI BASE24-eps / UPF
                    </div>
                    <h1 class="hero-title">
                        Expertos en
                        <span class="gradient-text">ACI BASE24-eps</span>
                    </h1>
                    <p class="hero-desc">
                        Consultoría especializada en diseño, arquitectura e implementación de soluciones
                        de pago basadas en la plataforma ACI BASE24-eps y UPF. Presencia en 7 países de
                        América Latina y Europa.
                    </p>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <span class="stat-val">7+</span>
                            <span class="stat-label">Países</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-val">15+</span>
                            <span class="stat-label">Proyectos</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-val">10+</span>
                            <span class="stat-label">Años</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item stat-item--link" id="expertos-btn">
                            <span class="stat-val stat-val--accent">&#128100;</span>
                            <span class="stat-label">Expertos</span>
                        </div>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="presence-card">
                        <div class="presence-header">
                            <span class="presence-dot"></span>
                            Presencia Global
                        </div>
                        <div class="world-map-wrap" id="world-map-wrap"></div>
                        <div class="country-legend">
                            <span class="country-dot latam"></span> Ecuador (×3) &nbsp;·&nbsp;
                            <span class="country-dot latam"></span> Colombia &nbsp;·&nbsp;
                            <span class="country-dot latam"></span> Panamá &nbsp;·&nbsp;
                            <span class="country-dot latam"></span> Costa Rica &nbsp;·&nbsp;
                            <span class="country-dot latam"></span> Chile &nbsp;·&nbsp;
                            <span class="country-dot latam"></span> Argentina &nbsp;·&nbsp;
                            <span class="country-dot eu"></span> España
                        </div>
                    </div>
                </div>
            </div>

            <div class="process-section">
                <p class="process-label">Metodología de Consultoría</p>
                <div class="process-flow">
                    <div class="process-card" id="validacion-btn">
                        <div class="process-icon">&#128270;</div>
                        <div class="process-name">Diagnóstico</div>
                        <div class="process-desc">Análisis &amp; Levantamiento</div>
                    </div>
                    <div class="process-arrow">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 11H18M18 11L12 5M18 11L12 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="process-card" id="enrutamiento-btn">
                        <div class="process-icon">&#128208;</div>
                        <div class="process-name">Diseño</div>
                        <div class="process-desc">Arquitectura &amp; Solución</div>
                    </div>
                    <div class="process-arrow">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 11H18M18 11L12 5M18 11L12 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="process-card" id="autorizacion-btn">
                        <div class="process-icon">&#128295;</div>
                        <div class="process-name">Implementación</div>
                        <div class="process-desc">Configuración &amp; Go-Live</div>
                    </div>
                    <div class="process-arrow">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 11H18M18 11L12 5M18 11L12 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="process-card" id="journal-btn">
                        <div class="process-icon">&#128101;</div>
                        <div class="process-name">Soporte</div>
                        <div class="process-desc">Mantenimiento &amp; Evolución</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios-section" class="section hidden">
        <div class="section-inner">
            <div class="section-header">
                <h2 class="section-title">Nuestros <span class="gradient-text">Servicios</span></h2>
                <p class="section-desc">Ofrecemos consultoría integral en todas las fases del ciclo de vida de soluciones ACI BASE24-eps y UPF, desde el diseño hasta la operación.</p>
            </div>

            <div class="content-card">
                <div class="card-image" style="background-image: url('/images/arquitectura-diagram.png');"></div>
                <div class="card-body">
                    <span class="card-tag">Servicio Principal</span>
                    <h3>Arquitectura de Soluciones de Pago</h3>
                    <p>Diseño y documentación de arquitecturas transaccionales de alta disponibilidad sobre la plataforma ACI BASE24-eps, incluyendo integración con redes internacionales y core bancario.</p>
                </div>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">&#128270;</div>
                    <h3>Consultoría Técnica</h3>
                    <p>Levantamiento, análisis y diagnóstico de plataformas BASE24-eps existentes para identificar brechas y oportunidades</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128200;</div>
                    <h3>Implementación UPF</h3>
                    <p>Diseño e implementación de flujos de pago modernos sobre ACI Universal Payments Framework</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128274;</div>
                    <h3>Seguridad &amp; HSM</h3>
                    <p>Configuración de módulos HSM, criptografía EMV, gestión de llaves y cumplimiento PCI-DSS</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128101;</div>
                    <h3>Transferencia de Conocimiento</h3>
                    <p>Capacitación de equipos técnicos locales en arquitectura, operación y mantenimiento de la plataforma</p>
                </div>
            </div>
        </div>
    </section>

    <!-- PLATAFORMA ACI -->
    <section id="plataforma-section" class="section hidden">
        <div class="section-inner">
            <div class="section-header">
                <h2 class="section-title">Plataforma <span class="gradient-text">ACI BASE24-eps</span></h2>
                <p class="section-desc">Dominio profundo de todos los módulos y capacidades de la plataforma ACI, aplicado a proyectos de alta exigencia en banca y medios de pago.</p>
            </div>

            <div class="content-card clickable" id="core-modules-link">
                <div class="card-image" style="background-image: url('/images/core-modules-diagram.png');"></div>
                <div class="card-body">
                    <span class="card-tag">Módulos Core</span>
                    <h3>AUTH, MDS, IFX, Journal &amp; más</h3>
                    <p>Experiencia en configuración y parametrización de los módulos principales del switch. Haz clic para ver el diagrama completo.</p>
                </div>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">&#128268;</div>
                    <h3>Canales &amp; Redes</h3>
                    <p>Integración con ATM, POS, e-commerce, Visa, Mastercard, redes locales y core bancario</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#9881;</div>
                    <h3>Parametrización</h3>
                    <p>Configuración de tablas, flujos de autorización, reglas de negocio y enrutamiento transaccional</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128202;</div>
                    <h3>Monitoreo &amp; Ops</h3>
                    <p>Definición de estrategias de operación, alertas, journaling y conciliación de transacciones</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">&#128640;</div>
                    <h3>Migración &amp; Upgrade</h3>
                    <p>Planificación y ejecución de migraciones de versiones y expansión de capacidades UPF</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SIMULADORES -->
    <section id="simuladores-section" class="section hidden">
        <div class="section-inner">
            <div class="section-header">
                <h2 class="section-title">Simuladores <span class="gradient-text">B24</span></h2>
                <p class="section-desc">Simuladores de flujo transaccional y plataformas bancarias para pruebas.</p>
            </div>

            <div class="simulators-grid">
                <div class="simulator-card">
                    <div class="sim-header">
                        <span class="sim-icon">&#127974;</span>
                        <h3>ProBank</h3>
                        <span class="sim-status active">Activo</span>
                    </div>
                    <p>Plataforma de simulacion bancaria para pruebas de core bancario con transacciones reales.</p>
                    <div class="sim-preview">
                        <div class="sim-preview-inner">
                            <span class="sim-preview-icon">&#128179;</span>
                            <span class="sim-preview-label">CORE SIMULATOR</span>
                        </div>
                    </div>
                    <a href="https://pro-bank-five.vercel.app/" target="_blank" rel="noopener noreferrer" class="sim-link">
                        Acceder al Simulador
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>

                <div class="simulator-card">
                    <div class="sim-header">
                        <span class="sim-icon">&#127975;</span>
                        <h3>ATM Flow</h3>
                        <span class="sim-status coming">En desarrollo</span>
                    </div>
                    <p>Simulador de flujo transaccional completo para cajeros automaticos ATM.</p>
                    <div class="sim-preview">
                        <div class="sim-preview-inner">
                            <span class="sim-preview-icon">&#128260;</span>
                            <span class="sim-preview-label">TRANSACTION FLOW</span>
                        </div>
                    </div>
                    <a href="#" class="sim-link disabled">Proximamente</a>
                </div>
            </div>
        </div>
    </section>

    <!-- MODULOS -->
    <section id="modulos-section" class="section hidden">
        <div class="section-inner">
            <div class="section-header">
                <h2 class="section-title">Core <span class="gradient-text">Modules</span></h2>
                <p class="section-desc">Modulos principales del sistema BASE24-eps.</p>
            </div>
            <div class="modules-diagram-wrap">
                <img src="/images/core-modules-diagram.png" alt="Diagrama de Modulos Core" class="modules-diagram">
            </div>
        </div>
    </section>

</main>

<!-- ===== FOOTER ===== -->
<footer class="footer">
    <div class="footer-inner">
        <div class="footer-left">
            <a href="mailto:whuera@gmail.com" class="footer-contact">
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
                whuera@gmail.com
            </a>
            <span class="footer-phone">+56 985689661 &middot; +593 995331328</span>
        </div>

        <div class="footer-center">
            <a href="https://whuera.github.io/index_fp.html" target="_blank" rel="noopener noreferrer" class="footer-link">PROJECTS</a>
            <a href="#" id="contact-btn-modal" class="footer-link highlight">CONTACT</a>
            <span class="footer-copy">&copy; <span id="year"></span> B24-eps &amp; UPF Consulting</span>
        </div>

        <div class="footer-right">
            <a href="https://github.com/whuera" target="_blank" rel="noopener noreferrer" class="footer-icon-btn" title="GitHub">
                <svg height="16" width="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            </a>
        </div>
    </div>
</footer>

<!-- ===== MODALS ===== -->

<!-- Diagnostico -->
<div id="validacion-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128270;</div>
        <h2>Diagnóstico &amp; Análisis</h2>
        <p class="modal-subtitle">Evaluación profunda del estado actual de la plataforma y definición de la hoja de ruta.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Levantamiento de Requerimientos</h3>
                <p>Entendimiento integral del negocio y la operación:</p>
                <ul>
                    <li>Revisión de la arquitectura existente BASE24-eps / UPF</li>
                    <li>Entrevistas con equipos técnicos y de negocio</li>
                    <li>Inventario de canales, redes y flujos transaccionales</li>
                </ul>
                <span class="modal-tag">Fase 1: Descubrimiento</span>
            </div>
            <div class="modal-section">
                <h3>Análisis de Brechas</h3>
                <p>Identificación de oportunidades de mejora:</p>
                <ul>
                    <li>Evaluación de cumplimiento PCI-DSS y EMV</li>
                    <li>Análisis de rendimiento y disponibilidad</li>
                    <li>Identificación de riesgos operativos</li>
                </ul>
                <span class="modal-tag">Fase 2: Evaluación</span>
            </div>
        </div>
    </div>
</div>

<!-- Diseño -->
<div id="enrutamiento-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128208;</div>
        <h2>Diseño de Arquitectura</h2>
        <p class="modal-subtitle">Propuesta de solución técnica detallada y alineada a los objetivos del negocio.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Arquitectura de la Solución</h3>
                <p>Diseño de componentes y flujos transaccionales:</p>
                <ul>
                    <li>Definición de módulos BASE24-eps (SRC_RTE, DST_RTE, AUTH)</li>
                    <li>Diseño de conectores con redes Visa, Mastercard e interbancarias</li>
                    <li>Estrategia de alta disponibilidad y recuperación ante fallas</li>
                </ul>
                <span class="modal-tag">Entregable: Documento de Arquitectura</span>
            </div>
            <div class="modal-section">
                <h3>Plan de Implementación</h3>
                <p>Hoja de ruta técnica y de proyecto:</p>
                <ul>
                    <li><strong style="color:var(--text)">Etapas:</strong> Desarrollo, pruebas, certificación y go-live</li>
                    <li><strong style="color:var(--text)">Riesgos:</strong> Identificación y plan de mitigación</li>
                    <li><strong style="color:var(--text)">Recursos:</strong> Equipo, herramientas y entornos necesarios</li>
                </ul>
                <span class="modal-tag">Entregable: Roadmap</span>
            </div>
        </div>
        <div class="modal-cta-block">
            <p class="modal-cta-text">
                Nuestros diseños de arquitectura son el resultado de años de experiencia en soluciones de pago de misión crítica.
                Le invitamos a explorar una muestra de nuestro portafolio técnico y comprobar el nivel de detalle, rigor y precisión que aplicamos en cada propuesta.
            </p>
            <a href="https://viewdiagram.vercel.app/" target="_blank" rel="noopener noreferrer" class="modal-cta-link">
                Explorar nuestros diseños de arquitectura
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="margin-left:6px;vertical-align:middle;"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
        </div>
    </div>
</div>

<!-- Implementación -->
<div id="autorizacion-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128295;</div>
        <h2>Implementación &amp; Go-Live</h2>
        <p class="modal-subtitle">Ejecución técnica de la solución diseñada, acompañamiento en certificaciones y salida a producción.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Configuración &amp; Parametrización</h3>
                <p>Implementación técnica sobre la plataforma ACI:</p>
                <ul>
                    <li>Parametrización de tablas y flujos BASE24-eps</li>
                    <li>Configuración de HSM, llaves criptográficas y EMV</li>
                    <li>Integración de canales ATM, POS y e-commerce</li>
                </ul>
                <span class="modal-tag">Tipo: Técnico</span>
            </div>
            <div class="modal-section">
                <h3>Certificación &amp; Pruebas</h3>
                <p>Validación con redes y reguladores:</p>
                <ul>
                    <li>Certificación Visa / Mastercard / redes locales</li>
                    <li>Pruebas de volumen, carga y recuperación</li>
                    <li>Acompañamiento en go-live y estabilización</li>
                </ul>
                <span class="modal-tag">Tipo: Certificación</span>
            </div>
        </div>
    </div>
</div>

<!-- Soporte -->
<div id="journal-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128101;</div>
        <h2>Soporte &amp; Evolución</h2>
        <p class="modal-subtitle">Acompañamiento continuo al equipo técnico y evolución de la plataforma en el tiempo.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Soporte Post-Implementación</h3>
                <p>Estabilización y continuidad operativa:</p>
                <ul>
                    <li>Atención de incidentes críticos de producción</li>
                    <li>Revisión de logs, journaling y conciliación</li>
                    <li>Ajustes de parametrización y optimización</li>
                </ul>
                <span class="modal-tag">Modalidad: Remota / On-Site</span>
            </div>
            <div class="modal-section">
                <h3>Transferencia de Conocimiento</h3>
                <p>Capacitación y autonomía del equipo local:</p>
                <ul>
                    <li>Talleres técnicos de BASE24-eps y UPF</li>
                    <li>Documentación operativa y runbooks</li>
                    <li>Asesoría en evolución hacia nuevas versiones</li>
                </ul>
                <span class="modal-tag">Modalidad: Capacitación</span>
            </div>
        </div>
    </div>
</div>

<!-- Contact -->
<div id="contact-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128233;</div>
        <h2>Contacto</h2>
        <p class="modal-subtitle">Dejanos tu mensaje y te contactaremos a la brevedad.</p>
