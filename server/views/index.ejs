<!-- ===== MAIN CONTENT ===== -->
<main class="main">

    <!-- INICIO -->
    <section id="inicio-section" class="section active">
        <div class="section-inner">
            <div class="hero">
                <div class="hero-content">
                    <div class="hero-badge">
                        <span class="badge-dot"></span>
                        Sistema Activo · ISO 8583
                    </div>
                    <h1 class="hero-title">
                        BASE24-eps
                        <span class="gradient-text">Switch Architecture</span>
                    </h1>
                    <p class="hero-desc">
                        Diseño de proyectos de software, arquitectura y consultoría para Fintech.
                        Procesamiento transaccional de alta disponibilidad para ATM, POS y e-commerce.
                    </p>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <span class="stat-val">99.99%</span>
                            <span class="stat-label">Uptime</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-val">&lt;1ms</span>
                            <span class="stat-label">Latencia</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-val">ISO8583</span>
                            <span class="stat-label">Protocolo</span>
                        </div>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="arch-diagram">
                        <div class="arch-image" style="background-image: url('/images/arquitectura-diagram.png');"></div>
                        <div class="arch-tag">Diagrama de Arquitectura Switch</div>
                    </div>
                </div>
            </div>

            <div class="process-section">
                <p class="process-label">Flujo Transaccional</p>
                <div class="process-flow">
                    <div class="process-card" id="validacion-btn">
