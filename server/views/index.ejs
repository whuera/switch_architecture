    <!-- ARQUITECTURA -->
    <section id="arquitectura-section" class="section hidden">
        <div class="section-inner">
            <div class="section-header">
                <h2 class="section-title">Arquitectura <span class="gradient-text">B24-eps</span></h2>
                <p class="section-desc">Diseno modular y escalable para el procesamiento de transacciones financieras.</p>
            </div>

            <div class="content-card">
                <div class="card-image" style="background-image: url('/images/arquitectura-diagram.png');"></div>
