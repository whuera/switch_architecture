<!-- ===== MODALS ===== -->

<!-- Validacion -->
<div id="validacion-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#9989;</div>
        <h2>Motor de Validacion</h2>
        <p class="modal-subtitle">Integridad y seguridad de los datos transaccionales.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Validacion de Formato</h3>
                <p>Asegura que el mensaje cumpla con los estandares:</p>
                <ul>
                    <li>ISO8583 (Versiones 87, 93, 2003)</li>
                    <li>Estructuras XML / JSON para APIs</li>
                    <li>Campos obligatorios y tipos de datos</li>
                </ul>
                <span class="modal-tag">Fase 1: Sintaxis</span>
            </div>
            <div class="modal-section">
                <h3>Validacion de Seguridad</h3>
                <p>Verificacion de credenciales y criptografia:</p>
                <ul>
                    <li>Validacion de PIN (PIN Block)</li>
                    <li>Verificacion de CVV/CVV2</li>
                    <li>Criptogramas EMV y llaves dinamicas</li>
                </ul>
                <span class="modal-tag">Fase 2: Seguridad</span>
            </div>
        </div>
    </div>
</div>

<!-- Enrutamiento -->
<div id="enrutamiento-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128260;</div>
        <h2>Motor de Enrutamiento</h2>
        <p class="modal-subtitle">Logica de decision y destino de transacciones.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Source Routing (SRC_RTE)</h3>
                <p>Evalua el origen de la transaccion basandose en:</p>
                <ul>
                    <li>PAN / BIN del cliente</li>
                    <li>Tipo de transaccion (ATM, POS, E-commerce)</li>
                    <li>Canal de entrada y Institution ID</li>
                </ul>
                <span class="modal-tag">Fase 1: Identificacion</span>
            </div>
            <div class="modal-section">
                <h3>Destination Routing (DST_RTE)</h3>
                <p>Determina el destino final para la autorizacion:</p>
                <ul>
                    <li><strong style="color:var(--text)">On-Us:</strong> Autorizacion interna en BASE24-eps</li>
                    <li><strong style="color:var(--text)">External Host:</strong> Core bancario o autorizador externo</li>
                    <li><strong style="color:var(--text)">Interchange:</strong> Redes internacionales (Visa, Mastercard)</li>
                </ul>
                <span class="modal-tag">Fase 2: Destino</span>
            </div>
        </div>
    </div>
</div>

<!-- Autorizacion -->
<div id="autorizacion-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128737;</div>
        <h2>Motor de Autorizacion</h2>
        <p class="modal-subtitle">Gestion de saldos y aprobacion de transacciones.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Autorizacion On-Us</h3>
                <p>Procesamiento interno para clientes del banco:</p>
                <ul>
                    <li>Consulta de saldos en tiempo real</li>
                    <li>Validacion de limites y bloqueos</li>
                    <li>Actualizacion de estados de cuenta</li>
                </ul>
                <span class="modal-tag">Tipo: Interno</span>
            </div>
            <div class="modal-section">
                <h3>Autorizacion Off-Us</h3>
                <p>Comunicacion con redes externas:</p>
                <ul>
                    <li>Envio a Interchanges (Visa/Mastercard)</li>
                    <li>Manejo de Timeouts y Reintentos</li>
                    <li>Traduccion de codigos de respuesta</li>
                </ul>
                <span class="modal-tag">Tipo: Externo</span>
            </div>
        </div>
    </div>
</div>

<!-- Journal -->
<div id="journal-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128221;</div>
        <h2>Sistema de Journaling</h2>
        <p class="modal-subtitle">Registro historico y auditoria de operaciones.</p>
        <div class="modal-sections">
            <div class="modal-section">
                <h3>Registro de Transacciones</h3>
                <p>Auditoria completa de cada paso:</p>
                <ul>
                    <li>Log de mensajes de entrada y salida</li>
                    <li>Tiempos de respuesta y latencia</li>
                    <li>Estado final de la transaccion</li>
                </ul>
                <span class="modal-tag">Funcion: Auditoria</span>
            </div>
            <div class="modal-section">
                <h3>Recuperacion y Reversas</h3>
                <p>Manejo de consistencia de datos:</p>
                <ul>
                    <li>Generacion automatica de reversas</li>
                    <li>Conciliacion de fin de dia</li>
                    <li>Recuperacion ante fallos del sistema</li>
                </ul>
                <span class="modal-tag">Funcion: Continuidad</span>
            </div>
        </div>
    </div>
</div>

<!-- Contact -->
<div id="contact-modal" class="modal">
    <div class="modal-box">
        <button class="modal-close close-modal">&#10005;</button>
        <div class="modal-icon">&#128233;</div>
        <h2>Contacto</h2>
        <p class="modal-subtitle">Dejanos tu mensaje y te contactaremos a la brevedad.</p>
        <form id="contact-form" class="contact-form">
            <div class="form-row">
                <div class="form-group">
                    <label>Nombre Completo</label>
                    <input type="text" name="name" placeholder="Tu nombre completo" required>
                </div>
                <div class="form-group">
                    <label>Documento de Identidad</label>
                    <input type="text" name="documentId" placeholder="Ej: 161625522" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Correo</label>
                    <input type="email" name="email" placeholder="tu@email.com" required>
                </div>
                <div class="form-group">
                    <label>Telefono</label>
                    <input type="tel" name="phone" placeholder="+56 9..." required>
                </div>
            </div>
            <div class="form-group">
                <label>Comentario</label>
                <textarea name="comment" rows="4" placeholder="En que podemos ayudarte?" required></textarea>
            </div>
            <button type="submit" class="submit-btn" id="submit-contact">Enviar Mensaje</button>
            <div id="form-response" class="form-response"></div>
        </form>
    </div>
</div>

<!-- Chatbot -->
<div id="chatbot-modal" class="modal">
    <div class="modal-box chatbot-box">
        <button class="modal-close" id="close-chatbot">&#10005;</button>
        <div class="chat-header">
            <div class="chat-avatar">&#129302;</div>
            <div>
                <h3>Asistente Virtual</h3>
                <p>IA experta en Arquitectura Switch</p>
            </div>
        </div>
        <div id="chat-messages" class="chat-messages">
            <div class="chat-msg assistant">
                Hola! Soy tu asistente experto en BASE24-eps. En que puedo ayudarte hoy?
            </div>
        </div>
        <div class="chat-input-area">
            <input type="text" id="chat-input" placeholder="Escribe tu consulta..." autocomplete="off">
            <button id="send-chat" class="chat-send">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
            </button>
        </div>
    </div>
</div>

<!-- ===== SCRIPTS ===== -->
<script src="/js/index.js"></script>
<script>
(function () {
    var canvas = document.getElementById('bg-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');

    var W, H, particles;

    var MAX_DIST_SQ = 18000; // ~134px conexion maxima
    var COLORS = ['#ffffff', '#6366f1', '#ffffff', '#3b82f6', '#ffffff', '#818cf8'];

    function Particle() {
        this.x  = Math.random() * W;
        this.y  = Math.random() * H;
        this.vx = (Math.random() - 0.5) * 0.55;
        this.vy = (Math.random() - 0.5) * 0.55;
        this.r  = Math.random() * 1.4 + 0.8;
        this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
        this.alpha = Math.random() * 0.4 + 0.4;
    }

    Particle.prototype.update = function () {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > W) this.vx = -this.vx;
        if (this.y < 0 || this.y > H) this.vy = -this.vy;
    };

    Particle.prototype.draw = function () {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
        ctx.fillStyle = this.color;
        ctx.globalAlpha = this.alpha;
        ctx.fill();
        ctx.globalAlpha = 1;
    };

    function init() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
        var count = Math.min(Math.floor((W * H) / 20000), 66);
        particles = [];
        for (var i = 0; i < count; i++) particles.push(new Particle());
    }

    function drawLines() {
        for (var i = 0; i < particles.length; i++) {
            for (var j = i + 1; j < particles.length; j++) {
                var dx = particles[i].x - particles[j].x;
                var dy = particles[i].y - particles[j].y;
                var dSq = dx * dx + dy * dy;
                if (dSq < MAX_DIST_SQ) {
                    var alpha = (1 - dSq / MAX_DIST_SQ) * 0.28;
                    ctx.beginPath();
                    ctx.strokeStyle = 'rgba(99,102,241,' + alpha + ')';
                    ctx.lineWidth = 0.7;
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.stroke();
                }
            }
        }
    }

    function animate() {
        ctx.clearRect(0, 0, W, H);
        for (var i = 0; i < particles.length; i++) {
            particles[i].update();
            particles[i].draw();
        }
        drawLines();
        requestAnimationFrame(animate);
    }

    init();
    animate();

    window.addEventListener('resize', init);
})();

// ===== APP LOGIC =====
document.addEventListener('DOMContentLoaded', function() {

    // Year
    var yearEl = document.getElementById('year');
    if (yearEl) yearEl.textContent = new Date().getFullYear();

    // ===== NAVIGATION =====
    var navLinks = document.querySelectorAll('[data-section]');
    var sections = {
        inicio:       document.getElementById('inicio-section'),
        arquitectura: document.getElementById('arquitectura-section'),
        componentes:  document.getElementById('componentes-section'),
        simuladores:  document.getElementById('simuladores-section'),
        modulos:      document.getElementById('modulos-section')
    };

    function showSection(name) {
        Object.keys(sections).forEach(function(key) {
            var el = sections[key];
            if (!el) return;
            if (key === name) {
                el.classList.remove('hidden');
                el.classList.add('fade-in');
                setTimeout(function() { el.classList.remove('fade-in'); }, 400);
            } else {
                el.classList.add('hidden');
            }
        });
        navLinks.forEach(function(link) {
            link.classList.toggle('active', link.dataset.section === name);
        });
    }

    navLinks.forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            showSection(link.dataset.section);
        });
    });

    var coreLink = document.getElementById('core-modules-link');
    if (coreLink) coreLink.addEventListener('click', function() { showSection('modulos'); });

    // ===== MODALS =====
    var modalConfigs = [
        { btnId: 'validacion-btn',   modalId: 'validacion-modal' },
        { btnId: 'enrutamiento-btn', modalId: 'enrutamiento-modal' },
        { btnId: 'autorizacion-btn', modalId: 'autorizacion-modal' },
        { btnId: 'journal-btn',      modalId: 'journal-modal' },
        { btnId: 'contact-btn-modal',modalId: 'contact-modal' }
    ];

    function openModal(id) {
        var m = document.getElementById(id);
        if (m) m.style.display = 'flex';
    }

    function closeModal(id) {
        var m = document.getElementById(id);
        if (!m) return;
        m.style.display = 'none';
        if (id === 'contact-modal') {
            var f = document.getElementById('contact-form');
            var r = document.getElementById('form-response');
            if (f) f.reset();
            if (r) { r.className = 'form-response'; r.textContent = ''; }
        }
    }

    modalConfigs.forEach(function(cfg) {
        var btn   = document.getElementById(cfg.btnId);
        var modal = document.getElementById(cfg.modalId);
        if (!btn || !modal) return;

        btn.addEventListener('click', function(e) { e.preventDefault(); openModal(cfg.modalId); });

        modal.querySelectorAll('.close-modal').forEach(function(el) {
            el.addEventListener('click', function() { closeModal(cfg.modalId); });
        });

        modal.addEventListener('click', function(e) {
            if (e.target === modal) closeModal(cfg.modalId);
        });
    });

    // ===== CHATBOT =====
    var chatbotModal  = document.getElementById('chatbot-modal');
    var consultameBtn = document.getElementById('consultame-btn');
    var closeChatbot  = document.getElementById('close-chatbot');
    var chatInput     = document.getElementById('chat-input');
    var sendChat      = document.getElementById('send-chat');
    var chatMessages  = document.getElementById('chat-messages');

    if (consultameBtn) {
        consultameBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (chatbotModal) chatbotModal.style.display = 'flex';
        });
    }
    if (closeChatbot) {
        closeChatbot.addEventListener('click', function() {
            if (chatbotModal) chatbotModal.style.display = 'none';
        });
    }
    if (chatbotModal) {
        chatbotModal.addEventListener('click', function(e) {
            if (e.target === chatbotModal) chatbotModal.style.display = 'none';
        });
    }

    function addMsg(text, type) {
        var div = document.createElement('div');
        div.className = 'chat-msg ' + type;
        div.textContent = text;
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        return div;
    }

    async function sendMessage() {
        var text = chatInput.value.trim();
        if (!text) return;
        addMsg(text, 'user');
        chatInput.value = '';
        var typing = addMsg('...', 'assistant');
        try {
            var res = await fetch('https://whuera.app.n8n.cloud/webhook/rag-query', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ query: text, chatInput: text })
            });
            chatMessages.removeChild(typing);
            if (!res.ok) throw new Error('Error');
            var data = await res.json();
            var out = Array.isArray(data)
                ? (data[0].output || data[0].response || JSON.stringify(data[0]))
                : (data.output || data.response || String(data));
            addMsg(out, 'assistant');
        } catch (err) {
            if (typing.parentNode) chatMessages.removeChild(typing);
            addMsg('Error de conexion. Verifica que el servicio este activo.', 'error');
        }
    }

    if (sendChat)  sendChat.addEventListener('click', sendMessage);
    if (chatInput) chatInput.addEventListener('keypress', function(e) { if (e.key === 'Enter') sendMessage(); });

    // ===== CONTACT FORM =====
    var contactForm = document.getElementById('contact-form');
    var submitBtn   = document.getElementById('submit-contact');
    var formResp    = document.getElementById('form-response');

    if (contactForm) {
        contactForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.classList.add('loading');
            submitBtn.textContent = 'Enviando...';
            formResp.textContent = '';
            formResp.className = 'form-response';

            var fd = new FormData(contactForm);
            var parts = fd.get('name').trim().split(/\s+/);
            var payload = {
                firstName:   parts[0] || '',
                lastName:    parts.slice(1).join(' ') || ' ',
                email:       fd.get('email'),
                documentId:  fd.get('documentId'),
                phoneNumber: fd.get('phone'),
                comment:     fd.get('comment')
            };

            try {
                var res = await fetch('https://azure-app-shopping-cart-reload-225fb76523b0.herokuapp.com/api/customer/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (res.ok) {
                    formResp.textContent = 'Mensaje enviado con exito!';
                    formResp.classList.add('success');
                    contactForm.reset();
                } else { throw new Error(); }
            } catch {
                formResp.textContent = 'Servicio no disponible por el momento';
                formResp.classList.add('error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.textContent = 'Enviar Mensaje';
            }
        });
    }
});
</script>
</body>
</html>
