<script src="/js/index.js"></script>
<script>
(function () {
    var canvas = document.getElementById('bg-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');

    var W, H, particles;

    var MAX_DIST_SQ = 18000; // ~134px conexion maxima
    var COLORS = ['#ffffff', '#6366f1', '#ffffff', '#3b82f6', '#ffffff', '#818cf8'];

    function Particle() {
        this.x  = Math.random() * W;
        this.y  = Math.random() * H;
        this.vx = (Math.random() - 0.5) * 0.55;
        this.vy = (Math.random() - 0.5) * 0.55;
        this.r  = Math.random() * 1.4 + 0.8;
        this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
        this.alpha = Math.random() * 0.4 + 0.4;
    }

    Particle.prototype.update = function () {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > W) this.vx = -this.vx;
        if (this.y < 0 || this.y > H) this.vy = -this.vy;
    };

    Particle.prototype.draw = function () {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
        ctx.fillStyle = this.color;
        ctx.globalAlpha = this.alpha;
        ctx.fill();
        ctx.globalAlpha = 1;
    };

    function init() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
        var count = Math.min(Math.floor((W * H) / 20000), 66);
        particles = [];
        for (var i = 0; i < count; i++) particles.push(new Particle());
    }

    function drawLines() {
        for (var i = 0; i < particles.length; i++) {
            for (var j = i + 1; j < particles.length; j++) {
                var dx = particles[i].x - particles[j].x;
                var dy = particles[i].y - particles[j].y;
                var dSq = dx * dx + dy * dy;
                if (dSq < MAX_DIST_SQ) {
                    var alpha = (1 - dSq / MAX_DIST_SQ) * 0.28;
                    ctx.beginPath();
                    ctx.strokeStyle = 'rgba(99,102,241,' + alpha + ')';
                    ctx.lineWidth = 0.7;
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.stroke();
                }
            }
        }
    }

    function animate() {
        ctx.clearRect(0, 0, W, H);
        for (var i = 0; i < particles.length; i++) {
            particles[i].update();
            particles[i].draw();
        }
        drawLines();
        requestAnimationFrame(animate);
    }

    init();
    animate();

    window.addEventListener('resize', init);
})();

// ===== APP LOGIC =====
document.addEventListener('DOMContentLoaded', function() {

    // Year
    var yearEl = document.getElementById('year');
    if (yearEl) yearEl.textContent = new Date().getFullYear();

    // ===== NAVIGATION =====
    var navLinks = document.querySelectorAll('[data-section]');
    var sections = {
        inicio:      document.getElementById('inicio-section'),
        servicios:   document.getElementById('servicios-section'),
        plataforma:  document.getElementById('plataforma-section'),
        simuladores: document.getElementById('simuladores-section'),
        modulos:     document.getElementById('modulos-section')
    };

    function showSection(name) {
        Object.keys(sections).forEach(function(key) {
            var el = sections[key];
            if (!el) return;
            if (key === name) {
                el.classList.remove('hidden');
                el.classList.add('fade-in');
                setTimeout(function() { el.classList.remove('fade-in'); }, 400);
            } else {
                el.classList.add('hidden');
            }
        });
        navLinks.forEach(function(link) {
            link.classList.toggle('active', link.dataset.section === name);
        });
    }

    navLinks.forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            showSection(link.dataset.section);
        });
    });

    var coreLink = document.getElementById('core-modules-link');
    if (coreLink) coreLink.addEventListener('click', function() { showSection('modulos'); });

    // ===== MODALS =====
    var modalConfigs = [
        { btnId: 'validacion-btn',   modalId: 'validacion-modal' },
        { btnId: 'enrutamiento-btn', modalId: 'enrutamiento-modal' },
        { btnId: 'autorizacion-btn', modalId: 'autorizacion-modal' },
        { btnId: 'journal-btn',      modalId: 'journal-modal' },
        { btnId: 'contact-btn-modal',modalId: 'contact-modal' }
    ];

    function openModal(id) {
        var m = document.getElementById(id);
        if (m) m.style.display = 'flex';
    }

    function closeModal(id) {
        var m = document.getElementById(id);
        if (!m) return;
        m.style.display = 'none';
        if (id === 'contact-modal') {
            var f = document.getElementById('contact-form');
            var r = document.getElementById('form-response');
            if (f) f.reset();
            if (r) { r.className = 'form-response'; r.textContent = ''; }
        }
    }

    // Expertos modal
    var expertosBtn = document.getElementById('expertos-btn');
    var expertosModal = document.getElementById('expertos-modal');
    if (expertosBtn && expertosModal) {
        expertosBtn.addEventListener('click', function() { expertosModal.style.display = 'flex'; });
        expertosModal.querySelectorAll('.close-modal').forEach(function(el) {
            el.addEventListener('click', function() { expertosModal.style.display = 'none'; });
        });
        expertosModal.addEventListener('click', function(e) {
            if (e.target === expertosModal) expertosModal.style.display = 'none';
        });
    }

    modalConfigs.forEach(function(cfg) {
        var btn   = document.getElementById(cfg.btnId);
        var modal = document.getElementById(cfg.modalId);
        if (!btn || !modal) return;

        btn.addEventListener('click', function(e) { e.preventDefault(); openModal(cfg.modalId); });

        modal.querySelectorAll('.close-modal').forEach(function(el) {
            el.addEventListener('click', function() { closeModal(cfg.modalId); });
        });

        modal.addEventListener('click', function(e) {
            if (e.target === modal) closeModal(cfg.modalId);
        });
    });

    // ===== CHATBOT =====
    var chatbotModal  = document.getElementById('chatbot-modal');
    var consultameBtn = document.getElementById('consultame-btn');
    var closeChatbot  = document.getElementById('close-chatbot');
    var chatInput     = document.getElementById('chat-input');
    var sendChat      = document.getElementById('send-chat');
    var chatMessages  = document.getElementById('chat-messages');

    if (consultameBtn) {
        consultameBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (chatbotModal) chatbotModal.style.display = 'flex';
        });
    }
    if (closeChatbot) {
        closeChatbot.addEventListener('click', function() {
            if (chatbotModal) chatbotModal.style.display = 'none';
        });
    }
    if (chatbotModal) {
        chatbotModal.addEventListener('click', function(e) {
            if (e.target === chatbotModal) chatbotModal.style.display = 'none';
        });
    }

    function addMsg(text, type) {
        var div = document.createElement('div');
        div.className = 'chat-msg ' + type;
        div.textContent = text;
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        return div;
    }

    async function sendMessage() {
        var text = chatInput.value.trim();
        if (!text) return;
        addMsg(text, 'user');
        chatInput.value = '';
        var typing = addMsg('...', 'assistant');
        try {
            var res = await fetch('https://whuera.app.n8n.cloud/webhook/rag-query', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ query: text, chatInput: text })
            });
            chatMessages.removeChild(typing);
            if (!res.ok) throw new Error('Error');
            var data = await res.json();
            var out = Array.isArray(data)
                ? (data[0].output || data[0].response || JSON.stringify(data[0]))
                : (data.output || data.response || String(data));
            addMsg(out, 'assistant');
        } catch (err) {
            if (typing.parentNode) chatMessages.removeChild(typing);
            addMsg('Error de conexion. Verifica que el servicio este activo.', 'error');
        }
    }

    if (sendChat)  sendChat.addEventListener('click', sendMessage);
    if (chatInput) chatInput.addEventListener('keypress', function(e) { if (e.key === 'Enter') sendMessage(); });

    // ===== CONTACT FORM =====
    var contactForm = document.getElementById('contact-form');
    var submitBtn   = document.getElementById('submit-contact');
    var formResp    = document.getElementById('form-response');

    if (contactForm) {
        contactForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.classList.add('loading');
            submitBtn.textContent = 'Enviando...';
            formResp.textContent = '';
            formResp.className = 'form-response';

            var fd = new FormData(contactForm);
            var parts = fd.get('name').trim().split(/\s+/);
            var payload = {
                firstName:   parts[0] || '',
                lastName:    parts.slice(1).join(' ') || ' ',
                email:       fd.get('email'),
                documentId:  fd.get('documentId'),
                phoneNumber: fd.get('phone'),
                comment:     fd.get('comment')
            };

            try {
                var res = await fetch('https://azure-app-shopping-cart-reload-225fb76523b0.herokuapp.com/api/customer/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (res.ok) {
                    formResp.textContent = 'Mensaje enviado con exito!';
                    formResp.classList.add('success');
                    contactForm.reset();
                } else { throw new Error(); }
            } catch {
                formResp.textContent = 'Servicio no disponible por el momento';
                formResp.classList.add('error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.textContent = 'Enviar Mensaje';
            }
        });
    }
});

// ===== WORLD MAP (D3 + Natural Earth) =====
window.addEventListener('load', function() {
    if (typeof d3 === 'undefined' || typeof topojson === 'undefined') return;
    renderWorldMap();
});

async function renderWorldMap() {
    var wrap = document.getElementById('world-map-wrap');
    if (!wrap) return;

    var W = wrap.offsetWidth || wrap.getBoundingClientRect().width || 480;
    var H = Math.round(W * 0.5);

    var svg = d3.select(wrap).append('svg')
        .attr('viewBox', '0 0 ' + W + ' ' + H)
        .style('width', '100%').style('height', 'auto').style('display', 'block');

    svg.append('rect').attr('width', W).attr('height', H).attr('fill', '#060d1a');

    var projection = d3.geoMercator()
        .scale(W / (2 * Math.PI) * 0.96)
        .translate([W / 2, H / 2 + H * 0.09]);

    var pathGen = d3.geoPath().projection(projection);

    // Graticule grid lines every 30°
    var graticule = d3.geoGraticule().step([30, 30]);
    svg.append('path').datum(graticule())
        .attr('d', pathGen).attr('fill', 'none')
        .attr('stroke', 'rgba(255,255,255,0.055)').attr('stroke-width', 0.5);

    // Load Natural Earth 110m world data
    var world;
    try {
        world = await d3.json('/countries-110m.json');
    } catch(e) {
        console.error('World map data failed:', e);
        return;
    }

    var countriesGeo = topojson.feature(world, world.objects.countries);
    var bordersGeo   = topojson.mesh(world, world.objects.countries, function(a, b) { return a !== b; });

    var hl = {
        '218': { fill: 'rgba(52,211,153,0.48)', stroke: 'rgba(52,211,153,0.78)' }, // Ecuador
        '170': { fill: 'rgba(52,211,153,0.45)', stroke: 'rgba(52,211,153,0.72)' }, // Colombia
        '591': { fill: 'rgba(52,211,153,0.42)', stroke: 'rgba(52,211,153,0.68)' }, // Panama
        '188': { fill: 'rgba(52,211,153,0.42)', stroke: 'rgba(52,211,153,0.68)' }, // Costa Rica
        '152': { fill: 'rgba(52,211,153,0.40)', stroke: 'rgba(52,211,153,0.65)' }, // Chile
        '32':  { fill: 'rgba(234,179,8,0.40)',  stroke: 'rgba(234,179,8,0.68)'  }, // Argentina
        '724': { fill: 'rgba(99,102,241,0.52)', stroke: 'rgba(99,102,241,0.88)' }, // Spain
    };

    svg.selectAll('path.c')
        .data(countriesGeo.features).join('path').attr('class', 'c')
        .attr('d', pathGen)
        .attr('fill',   function(d) { var h = hl[String(d.id)]; return h ? h.fill   : '#131e2e'; })
        .attr('stroke', function(d) { var h = hl[String(d.id)]; return h ? h.stroke : 'rgba(148,180,212,0.2)'; })
        .attr('stroke-width', function(d) { return hl[String(d.id)] ? 0.9 : 0.4; });

    svg.append('path').datum(bordersGeo).attr('d', pathGen)
        .attr('fill', 'none').attr('stroke', 'rgba(148,180,212,0.18)').attr('stroke-width', 0.4);

    // Glow filter
    var defs = svg.append('defs');
    var flt = defs.append('filter').attr('id', 'mglow');
    flt.append('feGaussianBlur').attr('stdDeviation', '3.5').attr('result', 'b');
    var mrg = flt.append('feMerge');
    mrg.append('feMergeNode').attr('in', 'b');
    mrg.append('feMergeNode').attr('in', 'SourceGraphic');

    // Capital-city marker positions
    var markers = [
        { lon: -78.47, lat: -0.23,  color: '#6366f1', large: true  }, // Ecuador
        { lon: -74.07, lat:  4.71,  color: '#34d399', large: false  }, // Colombia
        { lon: -79.52, lat:  8.99,  color: '#34d399', large: false  }, // Panama
        { lon: -84.09, lat:  9.93,  color: '#34d399', large: false  }, // Costa Rica
        { lon: -70.67, lat: -33.45, color: '#34d399', large: false  }, // Chile
        { lon: -58.38, lat: -34.60, color: '#eab308', large: false  }, // Argentina
        { lon:  -3.70, lat:  40.42, color: '#6366f1', large: true   }, // Spain
    ];

    // Connection lines (behind markers)
    function line(a, b, col) {
        var p1 = projection([a.lon, a.lat]);
        var p2 = projection([b.lon, b.lat]);
        if (!p1 || !p2) return;
        svg.append('line')
            .attr('x1', p1[0]).attr('y1', p1[1]).attr('x2', p2[0]).attr('y2', p2[1])
            .attr('stroke', col).attr('stroke-width', 0.8)
            .attr('stroke-dasharray', '3,3').attr('opacity', 0.32);
    }
    line(markers[0], markers[1], '#6366f1');
    line(markers[1], markers[2], '#34d399');
    line(markers[2], markers[3], '#34d399');
    line(markers[0], markers[4], '#34d399');
    line(markers[4], markers[5], '#eab308');

    // Arc Ecuador → Spain
    var ep = projection([markers[0].lon, markers[0].lat]);
    var sp = projection([markers[6].lon, markers[6].lat]);
    if (ep && sp) {
        svg.append('path')
            .attr('d', 'M'+ep[0]+','+ep[1]+' Q'+((ep[0]+sp[0])/2)+','+(Math.min(ep[1],sp[1])-H*0.22)+' '+sp[0]+','+sp[1])
            .attr('fill', 'none').attr('stroke', '#6366f1')
            .attr('stroke-width', 0.8).attr('stroke-dasharray', '4,4').attr('opacity', 0.22);
    }

    // Markers
    var mG = svg.append('g');
    markers.forEach(function(m) {
        var pos = projection([m.lon, m.lat]);
        if (!pos) return;
        var x = pos[0], y = pos[1], g = mG.append('g');
        var outerR = m.large ? 22 : 14, dotR = m.large ? 7 : 5.5;

        g.append('circle').attr('cx',x).attr('cy',y).attr('r', outerR)
            .attr('fill','none').attr('stroke', m.color).attr('stroke-width',1.5)
            .attr('opacity',0.15).attr('class','map-pulse');
        if (m.large) {
            g.append('circle').attr('cx',x).attr('cy',y).attr('r',14)
                .attr('fill','none').attr('stroke',m.color).attr('stroke-width',1).attr('opacity',0.26);
        }
        g.append('circle').attr('cx',x).attr('cy',y).attr('r',dotR)
            .attr('fill',m.color).attr('opacity',0.92).attr('filter','url(#mglow)');
        g.append('circle').attr('cx',x).attr('cy',y).attr('r',dotR*0.38).attr('fill','white');
    });
}
</script>
